# Aqlis environment variables.
# Copy to apps/server/.env and fill in real values. NEVER commit .env.

# Neon Postgres — POOLED connection (hostname contains "-pooler").
# Used by the app at runtime.
DATABASE_URL="postgresql://USER:PASSWORD@ep-example-pooler.eu-west-2.aws.neon.tech/neondb?sslmode=require"

# Neon Postgres — DIRECT connection (same string, no "-pooler").
# Used only by Prisma migrations / CLI tooling.
DIRECT_DATABASE_URL="postgresql://USER:PASSWORD@ep-example.eu-west-2.aws.neon.tech/neondb?sslmode=require"
